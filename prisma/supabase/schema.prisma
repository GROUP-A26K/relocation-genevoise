generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/supabase-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DATABASE_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model contact {
  id         Int      @id @default(autoincrement())
  first_name String   @db.VarChar(60)
  last_name  String   @db.VarChar(60)
  email      String   @db.VarChar(255)
  phone      String   @db.VarChar(15)
  company    String?  @db.VarChar(255)
  subject    String   @db.VarChar(255)
  message    String?  @db.Text
  accept     Boolean
  created_at DateTime @db.Timestamp(0)
}

model booking {
  id          Int      @id @default(autoincrement())
  phone       String   @db.VarChar(15)
  accept      Boolean
  contact_via String   @db.VarChar(255)
  created_at  DateTime @db.Timestamp(0)
}

model subscribe {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  created_at DateTime @db.Timestamp(0)
}

model application {
  id               Int      @id @default(autoincrement())
  first_name       String   @db.VarChar(60)
  last_name        String   @db.VarChar(60)
  email            String   @db.VarChar(255)
  phone            String   @db.VarChar(15)
  experience_years String   @db.VarChar(255)
  expected_ctc     Decimal? @db.Decimal(12, 2)
  resume_url       String   @db.VarChar(512)
  department       String   @db.VarChar(255)
  position         String   @db.VarChar(255)
  accept           Boolean
  created_at       DateTime @db.Timestamp(0)
}
